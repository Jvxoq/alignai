# Frontend — only used when running the dev server directly on the host:
#   cp .env.example .env && npm run dev
# Inside docker-compose, this is passed as a build ARG in docker-compose.yml.
#
# WARNING: every VITE_* variable is inlined into the public JS bundle at build
# time and is readable by anyone who loads the site. Only put PUBLIC values
# here (e.g. API base URLs). NEVER put secrets (API keys, tokens) in VITE_*.

VITE_API_BASE_URL=http://localhost:8000
