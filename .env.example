# Copy to .env and fill in values:
#   cp .env.example .env
#
# Note: backend/.env, agent/.env, frontend/.env are separate
# for running services on the host (outside Docker).

GROQ_API_KEY=
GEMINI_API_KEY=
# Qdrant Cloud — the agent connects here (no local Qdrant container)
QDRANT_URL=
QDRANT_API_KEY=
# Required: the LangGraph platform server (agent) uses this for its license
# check and won't start without it. Get one at https://smith.langchain.com
LANGSMITH_API_KEY=
# Optional: set to "true" to send traces to LangSmith (defaults to false).
LANGCHAIN_TRACING_V2=false
