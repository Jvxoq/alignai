# =============================================================================
# AlignAI — Unified Environment Reference
# =============================================================================
# Copy per-service examples for local development:
#   backend/.env.example  → backend/.env
#   agent/.env.example    → agent/.env
#   frontend/.env.example → frontend/.env
# =============================================================================

# --- Backend (FastAPI) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/alignai
LANGGRAPH_URL=http://localhost:8123
LANGGRAPH_API_KEY=
MESSAGE_THRESHOLD=10
LOG_LEVEL=INFO

# --- Agent (LangGraph) ---
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=alignai_docs
GEMINI_API_KEY=
EMBEDDING_MODEL=text-embedding-004
# LOG_LEVEL=INFO  (shared with backend)

# --- Frontend (React / Vite) ---
VITE_API_BASE_URL=http://localhost:8000
