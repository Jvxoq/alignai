# DEVELOPMENT image — installs dev deps (pytest, ruff, mypy) and runs uvicorn
# with --reload. Source is bind-mounted by docker-compose.override.yml, so edits
# on the host restart the server live and tests run inside the container:
#   docker compose exec backend .venv/bin/pytest
# For the lean PRODUCTION build see ./Dockerfile.
FROM python:3.12-slim

RUN adduser --disabled-password --gecos "" appuser

WORKDIR /app

RUN pip install uv --no-cache-dir

RUN chown appuser:appuser /app

USER appuser

# Install dependencies WITH the dev group (no --no-dev) for layer caching.
COPY --chown=appuser:appuser pyproject.toml uv.lock ./
RUN uv sync --frozen

# Copy source so the image runs standalone; the compose bind-mount overlays it
# at runtime for hot-reload.
COPY --chown=appuser:appuser app/ ./app/
COPY --chown=appuser:appuser main.py alembic.ini ./
COPY --chown=appuser:appuser migrations/ ./migrations/

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s \
  CMD [".venv/bin/python", "-c", "import httpx; httpx.get('http://localhost:8000/health').raise_for_status()"]

# Run migrations, then uvicorn with --reload (watches the bind-mounted source).
CMD ["sh", "-c", ".venv/bin/alembic upgrade head && .venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000 --reload"]
