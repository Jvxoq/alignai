# Backend — only used when running the service directly on the host:
#   cp .env.example .env && uv run uvicorn main:app --reload
# Inside docker-compose, these are already set in docker-compose.yml.

# Local dev value below. For production (Neon), set POSTGRES_URL to your Neon
# DIRECT connection string (host without "-pooler"); paste it raw — the backend
# normalizes the scheme to +asyncpg and sslmode=→ssl= automatically.
POSTGRES_URL=postgresql+asyncpg://postgres:password@localhost:5432/alignai
LANGGRAPH_SERVER_URL=http://localhost:8123
SECRET_KEY=
CORS_ORIGINS=["http://localhost:5173"]
ENVIRONMENT=development

# No need to keep a local agent warm.
AGENT_KEEP_ALIVE_ENABLED=false
