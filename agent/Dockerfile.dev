# DEVELOPMENT image — lightweight `langgraph dev` server (in-memory checkpointing,
# no Redis/Postgres needed). Source is bind-mounted by docker-compose.override.yml
# for hot-reload, so we install dev deps (pytest, ruff) but don't need to bake in
# the latest app code. For the PRODUCTION build see ./Dockerfile.
FROM python:3.12-slim

RUN adduser --disabled-password --gecos "" appuser

WORKDIR /app

RUN pip install uv --no-cache-dir

RUN chown appuser:appuser /app

USER appuser

# Install ALL dependencies incl. the dev group (pytest, ruff) so tests can run
# inside the container: `docker compose exec agent .venv/bin/pytest`.
COPY --chown=appuser:appuser pyproject.toml uv.lock ./
RUN uv sync --frozen

COPY --chown=appuser:appuser app/ ./app/
COPY --chown=appuser:appuser langgraph.json ./

EXPOSE 8123

HEALTHCHECK --interval=30s --timeout=10s --start-period=10s \
  CMD [".venv/bin/python", "-c", "import httpx; httpx.get('http://localhost:8123/ok').raise_for_status()"]

# `langgraph dev` runs the API server with hot-reload and in-memory checkpointing.
# Call the venv binary directly — `uv run` would re-sync deps at startup.
CMD [".venv/bin/langgraph", "dev", "--host", "0.0.0.0", "--port", "8123"]
