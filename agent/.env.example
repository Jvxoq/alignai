# Agent — only used when running the service directly on the host:
#   cp .env.example .env && uv run langgraph dev
# Inside docker-compose, these are already set in docker-compose.yml.

# Qdrant Cloud cluster URL (e.g. https://xxxx.cloud.qdrant.io:6333)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=alignai_docs
GROQ_API_KEY=
GEMINI_API_KEY=
ENVIRONMENT=development

# Optional per-node model overrides (same provider, Groq). Defaults to
# llama-3.3-70b-versatile for both if unset — see app/core/config.py.
# INTENT_LLM_MODEL=
# GENERATOR_LLM_MODEL=
